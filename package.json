{
  "name": "project-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "node scripts/check-vercel-env.mjs && next build",
    "start": "next start",
    "start:dev": "npm run dev",
    "start:prod": "npm run build && npm run start",
    "lint": "eslint",
    "vercel:env": "bash scripts/print-vercel-env.sh"
